NODE_ENV=production
PORT=5000

MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/vireon?retryWrites=true&w=majority

JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=30d
RESET_TOKEN_EXPIRES_IN=15m

FRONTEND_URL=https://your-frontend.example.com
ADDITIONAL_CORS_ORIGINS=https://preview.example.com

EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM=Vireon <noreply@vireon.com>
ADMIN_EMAIL=admin@vireon.com

RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_secret

LOG_LEVEL=info
BODY_LIMIT=1mb
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
AUTH_RATE_LIMIT_MAX=25
SEED_DATABASE=false
